        }
      }
    },
    {
      "id": "n4",
      "name": "Build Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        300
      ],
      "parameters": {
        "jsCode": "const items = $('Input from MAIN').all().map(i => i.json);\nconst sys = Buffer.from($('Load System').first().json.content,'base64').toString('utf-8');\nconst usrTemplate = Buffer.from($('Load User').first().json.content,'base64').toString('utf-8');\n\nreturn items.map(inp => {\n  let usr = usrTemplate;\n  const vars = {\n    course_id: inp.course_id||'', target_language: inp.target_language||'en-US',\n    domain: inp.detected_domain||'',\n    adapted_content: inp.translated_html||inp.html||''\n  };\n  Object.entries(vars).forEach(([k,v]) => {\n    usr = usr.replace(new RegExp('\\\\{{'+k+'\\\\}}','g'), String(v));\n  });\n  return {json:{\n    system_prompt: sys, user_message: usr,\n    model: 'gpt-5.2', temperature: 0.1, max_tokens: 16000,\n    custom_id: (inp.course_id||'x')+'-ch'+(inp.chapter_index||0)+'-ck'+(inp.chunk_index||1)+'-a6',\n    agent_name: 'A6 Final Proofreader', course_id: inp.course_id,\n    chapter_index: inp.chapter_index, chunk_index: inp.chunk_index,\n    pipeline_meta: inp.pipeline_meta||{}\n  }};\n});"
      }
    },
    {
      "id": "n5",
      "name": "Call Submitter",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        960,
        300
      ],
      "parameters": {
        "workflowId": "P2YD7sOqf6uMAtqU",
        "mode": "passThrough"
      }
    },
    {
      "id": "n6",
      "name": "Call Poller",
      "type": "n8n-nodes-base.executeWorkflow",
      "typeVersion": 1,
      "position": [
        1220,
        300
      ],
      "parameters": {
        "workflowId": "HDdfFxAIS1qnLUEe",
        "mode": "passThrough"
      }
    },
    {
      "id": "n7",
      "name": "Return Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1480,
        300
      ],
      "parameters": {
        "jsCode": "const p = $input.first().json;\nconst origItems = $('Input from MAIN').all().map(i => i.json);\nconst results = p.results || [{custom_id: null, parsed_content: p.agent_output}];\n\nconst rMap = {};\nresults.forEach(r => {\n  const m = (r.custom_id||'').match(/-ch(\\d+)-ck(\\d+)-/);\n  if(m) rMap[m[1]+'-'+m[2]] = r.parsed_content;\n});\n\nif(p.status==='failed'||p.status==='timed_out')\n  return origItems.map(orig => ({json:{\n    status:'error', agent:'A6 Final Proofreader', error:p.error, escalation:true,\n    course_id:p.course_id||orig.course_id,\n    chapter_index:orig.chapter_index||0, chunk_index:orig.chunk_index||1\n  }}));\n\nreturn origItems.map(orig => {\n  const key = (orig.chapter_index||0)+'-'+(orig.chunk_index||1);\n  const ao = rMap[key] || results[0]?.parsed_content || null;\n  return {json:{\n    status:'ok', agent:'A6 Final Proofreader', agent_output:ao,\n    course_id:p.course_id||orig.course_id,\n    chapter_index:orig.chapter_index||0, chunk_index:orig.chunk_index||1,\n    pipeline_meta:p.pipeline_meta||{},\n    source_language:orig.source_language||'fr',\n    target_language:orig.target_language||'en-US',\n    target_course_id:orig.target_course_id||'',\n    enabled_modules:orig.enabled_modules||{},\n    html:orig.html||orig.source_html||''\n  }};\n});"
      }
    }
  ],
