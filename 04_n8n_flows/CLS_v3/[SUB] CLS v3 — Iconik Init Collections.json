          "parent_collection_id": "={{ $('Extract Target ID').first().json.target_collection_id }}"
        }
      }
    },
    {
      "id": "create_transcripts",
      "name": "Create transcripts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1320,
        440
      ],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "POST",
        "url": "https://app.iconik.io/API/assets/v1/collections/",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "App-ID",
              "value": "={{ $('Build Auth').first().json.iconik_app_id }}"
            },
            {
              "name": "Auth-Token",
              "value": "={{ $('Build Auth').first().json.iconik_auth_token }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": {
          "title": "transcripts",
          "parent_collection_id": "={{ $('Extract Target ID').first().json.target_collection_id }}"
        }
      }
    },
    {
      "id": "return_ids",
      "name": "Return Collection IDs",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1560,
        300
      ],
      "parameters": {
        "jsCode": "const etgt = $('Extract Target ID').first().json;\nconst g_id = (() => { try { return $('Create static_graphics').first().json.id||null; } catch{return null;} })();\nconst f_id = (() => { try { return $('Create external_files').first().json.id||null; } catch{return null;} })();\nconst t_id = (() => { try { return $('Create transcripts').first().json.id||null; } catch{return null;} })();\nreturn [{json:{\n  target_course_id:          etgt.target_course_id,\n  root_collection_id:        etgt.root_collection_id,\n  target_collection_id:      etgt.target_collection_id,\n  graphics_collection_id:    g_id,\n  files_collection_id:       f_id,\n  transcripts_collection_id: t_id,\n  iconik_ready: !!(g_id && f_id && t_id)\n}}];"
      }
    }
