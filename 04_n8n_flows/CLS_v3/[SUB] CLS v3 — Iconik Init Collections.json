  "nodes": [
    {
      "id": "trigger",
      "name": "Input from MAIN",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [
        0,
        300
      ],
      "parameters": {}
    },
    {
      "id": "auth",
      "name": "Build Auth",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        220,
        300
      ],
      "parameters": {
        "jsCode": "// ── ICONIK CREDENTIALS ──────────────────────────────────────────\n// Replace the two values below with your Iconik App-ID and Auth-Token\n// Open this node in n8n UI → paste the values → Ctrl+S to save\nconst ICONIK_APP_ID     = 'PASTE_YOUR_APP_ID_HERE';\nconst ICONIK_AUTH_TOKEN = 'PASTE_YOUR_AUTH_TOKEN_HERE';\n// ─────────────────────────────────────────────────────────────────\n\nconst inp = $input.first().json;\nreturn [{json:{\n  target_course_id: inp.target_course_id,\n  iconik_app_id:    ICONIK_APP_ID,\n  iconik_auth_token:ICONIK_AUTH_TOKEN,\n  root_collection_name: '0000_LOCALISATION'\n}}];"
      }
    },
    {
      "id": "search_root",
      "name": "Search Root Collection",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        440,
        300
      ],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "POST",
        "url": "https://app.iconik.io/API/search/v1/search/",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "App-ID",
              "value": "={{ $('Build Auth').first().json.iconik_app_id }}"
            },
            {
              "name": "Auth-Token",
              "value": "={{ $('Build Auth').first().json.iconik_auth_token }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": {
          "doc_types": [
            "=collections"
          ],
          "query": "=0000_LOCALISATION",
          "limit": 5
        }
      }
    },
    {
      "id": "find_root",
      "name": "Extract Root ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        300
      ],
      "parameters": {
        "jsCode": "const auth = $('Build Auth').first().json;\nconst res  = $input.first().json;\nconst objects = res.objects || [];\nconst match = objects.find(o => (o.title||'').trim() === '0000_LOCALISATION');\nreturn [{json:{\n  ...auth,\n  root_collection_id: match ? match.id : null,\n  root_found: !!match\n}}];"
      }
    },
    {
      "id": "create_target",
      "name": "Create Target Collection",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        880,
        300
      ],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "POST",
        "url": "https://app.iconik.io/API/assets/v1/collections/",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "App-ID",
              "value": "={{ $('Build Auth').first().json.iconik_app_id }}"
            },
            {
              "name": "Auth-Token",
              "value": "={{ $('Build Auth').first().json.iconik_auth_token }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": {
          "title": "={{ $('Build Auth').first().json.target_course_id }}",
          "parent_collection_id": "={{ $('Extract Root ID').first().json.root_collection_id }}"
        }
      }
    },
    {
      "id": "extract_target",
      "name": "Extract Target ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1100,
        300
      ],
      "parameters": {
        "jsCode": "const auth = $('Build Auth').first().json;\nreturn [{json:{\n  ...auth,\n  root_collection_id:   $('Extract Root ID').first().json.root_collection_id,\n  target_collection_id: $input.first().json.id || null\n}}];"
      }
    },
    {
      "id": "create_graphics",
      "name": "Create static_graphics",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1320,
        160
      ],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "POST",
        "url": "https://app.iconik.io/API/assets/v1/collections/",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "App-ID",
              "value": "={{ $('Build Auth').first().json.iconik_app_id }}"
            },
            {
              "name": "Auth-Token",
              "value": "={{ $('Build Auth').first().json.iconik_auth_token }}"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": {
          "title": "static_graphics",
          "parent_collection_id": "={{ $('Extract Target ID').first().json.target_collection_id }}"
        }
      }
    },
    {
      "id": "create_files",
      "name": "Create external_files",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        1320,
        300
      ],
      "onError": "continueRegularOutput",
      "parameters": {
        "method": "POST",
        "url": "https://app.iconik.io/API/assets/v1/collections/",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
