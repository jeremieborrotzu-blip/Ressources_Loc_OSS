      "parameters": {
        "jsCode": "\n// Inputs attendus de l'appelant : binary.data (fichier), json.filename, json.mime, json.collection_id\nreturn [{json:{\n  app_id:'***REMOVED***',\n  auth_token:'***REMOVED***',\n  storage_id:'***REMOVED***',\n  filename: $input.first().json.filename,\n  mime: $input.first().json.mime || 'application/octet-stream',\n  collection_id: $input.first().json.collection_id || null\n}}];\n"
      },
