        "headerParameters": {
          "parameters": [
            {
              "name": "App-ID",
              "value": "={{ $('Build Auth').first().json.app_id }}"
            },
            {
              "name": "Auth-Token",
              "value": "={{ $('Build Auth').first().json.auth_token }}"
            }
          ]
        },
        "options": {},
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"size\": {{ $('Compute Filesize').first().json.size }},\n  \"original_name\": {{ JSON.stringify($('Build Auth').first().json.filename) }},\n  \"directory_path\":\"\",\"type\":\"FILE\",\n  \"format_id\": {{ JSON.stringify($('Create Format').first().json.id) }},\n  \"file_set_id\": {{ JSON.stringify($('Create Fileset').first().json.id) }},\n  \"storage_id\": {{ JSON.stringify($('Build Auth').first().json.storage_id) }},\n  \"multipart_upload_url\":false\n}"
      },
      "id": "eafe3d99-9fcb-4c27-b0b2-7ff969731870",
      "name": "Create Upload URL",
