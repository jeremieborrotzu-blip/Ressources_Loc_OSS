        "specifyBody": "json",
        "jsonBody": "={\n  \"user_id\": {{ JSON.stringify($('Create Asset').first().json.created_by_user) }},\n  \"name\":\"ORIGINAL\",\n  \"metadata\":[{\"internet_media_type\": {{ JSON.stringify($('Build Auth').first().json.mime) }} }],\n  \"storage_methods\":[\"S3\"]\n}"
      },
