          ]
        },
        "options": {},
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"format_id\": {{ JSON.stringify($('Create Format').first().json.id) }},\n  \"storage_id\": {{ JSON.stringify($('Build Auth').first().json.storage_id) }},\n  \"base_dir\":\"/\",\n  \"name\": {{ JSON.stringify($('Build Auth').first().json.filename) }},\n  \"component_ids\":[]\n}"
      },
      "id": "0d1c2dd9-3953-4bd9-8608-f359c4e4cb60",
      "name": "Create Fileset",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        880,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "\n// taille EXACTE depuis binary.data.bytes (data = stub filesystem, fileSize = approx)\nconst b = $('Input from MAIN').first().binary.data;\nconst size = (typeof b.bytes === 'number') ? b.bytes : parseInt(b.bytes,10);\nreturn [{json:{ size }}];\n"
      },
      "id": "78987147-17c4-4299-ade5-62b217c68ae0",
      "name": "Compute Filesize",
      "type": "n8n-nodes-base.code",
