    {
      "parameters": {
        "jsCode": "// partIndex, partId, partName, chapterIndex, chapterId, chapterName\nlet collection = []\ncollection.push({\n  partIndex: 0,\n  partId: 0,\n  partName: \"Introduction\",\n  chapterIndex: 0,\n  chapterId: 0,\n  chapterName: \"Introduction\"\n})\n\n$(\"Get TOC\").first().json.children.forEach((part,pI)=>{\n  part.children.forEach((chapter, cI)=>{\n    if(chapter.type == \"title-2\"){\n        collection.push({\n        partIndex: pI + 1,\n        partId: part.id,\n        partName: part.title,\n        chapterIndex: cI + 1,\n        chapterId: chapter.id,\n        chapterName: chapter.title\n      })\n    }\n\n  })\n})\nreturn collection"
      },
