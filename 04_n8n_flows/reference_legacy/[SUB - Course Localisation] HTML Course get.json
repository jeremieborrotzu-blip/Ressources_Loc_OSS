    {
      "parameters": {
        "jsCode": "function sanitize(html){\n  return html\n    .replace(/\\s+id=([\"'])(.*?)\\1/g, '')\n    .replace(/\\s+data-claire-element-id=([\"'])(.*?)\\1/g, '');\n}\n\nconst input = $('Loop Over Items').all()\n\nreturn input.map(x=>{return {\n    ...x.json,\n    html: sanitize(x.json.html),\n  }\n})"
      },
