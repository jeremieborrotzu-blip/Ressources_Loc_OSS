    {
      "parameters": {
        "jsCode": "function downgradeHeadings(html){\n  return html.replace(/<h3\\b([^>]*)>/gi, '<h4$1>').replace(/<\\/h3>/gi, '</h4>');\n}\n\nconst input = $('Sanitize HTML').all();\n\nlet lastPartIndex = null;\nreturn input.map(element=>{\n  let headerBuffer = \"\";\n  if(element.json.partIndex == 0 && element.json.chapterIndex == 0){\n    // Intro\n  } else if( element.json.partIndex !== lastPartIndex){\n    // New partChapter\n    headerBuffer += `\\n<h2>${element.json.partName}</h2>\\n`\n    headerBuffer += `\\n<h3>${element.json.chapterName}</h3>\\n`\n  } else {\n    // New chapter\n    headerBuffer += `\\n<h3>${element.json.chapterName}</h3>\\n`\n  }\n  \n  lastPartIndex = element.json.partIndex\n\n  return {\n    ...element.json,\n    \"html\": headerBuffer += downgradeHeadings(element.json.html),\n  }\n})"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
