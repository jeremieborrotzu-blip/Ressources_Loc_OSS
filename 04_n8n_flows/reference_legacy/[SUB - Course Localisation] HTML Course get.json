      "parameters": {
        "jsCode": "return {\n  \"infos\": $(\"Get course\").first().json,\n  \"contents\": $(\"Add headings\").all(),\n  \"singlePageHTML\": $(\"Add headings\").all().map(x=>x.json.html).join('\\n')\n}"
