    {
      "id": "n4",
      "name": "Build Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        700,
        300
      ],
      "parameters": {
        "jsCode": "\nconst inp = $('Input from MAIN').first().json;\nconst sys = Buffer.from($('Load System').first().json.content,'base64').toString('utf-8');\nlet   usr = Buffer.from($('Load User').first().json.content,'base64').toString('utf-8');\nconst vars = {\n  course_id: inp.course_id||'', chapter_index: inp.chapter_index||0,\n  chunk_index: inp.chunk_index||1, source_language: inp.source_language||'fr',\n  target_language: inp.target_language||'en-US', detected_domain: inp.detected_domain||'',\n  html_content: inp.html||inp.html_content||'', source_html: inp.html||inp.source_html||'',\n  pretranslation_draft: inp.pretranslation_draft||'', translated_html: inp.translated_html||'',\n  preceding_context: inp.preceding_context||'',\n  a1_audit: JSON.stringify(inp.a1_audit||{}), a1_outputs: JSON.stringify(inp.a1_outputs||[]),\n  a2_glossary: JSON.stringify(inp.a2_glossary||{}), a4_swap_log: JSON.stringify(inp.a4_swap_log||[]),\n  common_glossary: JSON.stringify(inp.common_glossary||[]),\n  domain_validated_tm: JSON.stringify(inp.domain_validated_tm||[]),\n  domain_unvalidated_tm: JSON.stringify(inp.domain_unvalidated_tm||[]),\n  iteration: inp.iteration||1, failing_segments: JSON.stringify(inp.failing_segments||[]),\n  previous_qa_report: JSON.stringify(inp.previous_qa_report||{}),\n  score_target: inp.score_target||90\n};\nObject.entries(vars).forEach(([k,v]) => {\n  usr = usr.replace(new RegExp('\\\\{{'+k+'\\\\}}','g'), String(v));\n});\nreturn [{json:{\n  system_prompt: sys, user_message: usr,\n  model: 'gpt-5.4', temperature: 0.0, max_tokens: 16000,\n  custom_id: (inp.course_id||'x')+'-ch'+(inp.chapter_index||0)+'-ck'+(inp.chunk_index||1)+'-a2terminologyarchitect',\n  agent_name: 'A2 Terminology Architect', course_id: inp.course_id,\n  chapter_index: inp.chapter_index, chunk_index: inp.chunk_index,\n  pipeline_meta: inp.pipeline_meta||{}\n}}];\n"
      }
    },
    {
