    {
      "id": "n7",
      "name": "Return Output",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1480,
        300
      ],
      "parameters": {
        "jsCode": "\nconst p = $input.first().json;\nif(p.status==='failed'||p.status==='timed_out')\n  return [{json:{status:'error',agent:'A2 Terminology Architect',error:p.error,escalation:true,\n    course_id:p.course_id,chapter_index:p.chapter_index,chunk_index:p.chunk_index}}];\nreturn [{json:{status:'ok',agent:'A2 Terminology Architect',agent_output:p.agent_output||null,\n  course_id:p.course_id,chapter_index:p.chapter_index,chunk_index:p.chunk_index,\n  pipeline_meta:p.pipeline_meta||{}}}];\n"
      }
    }
